{
  "name": "firstmiledev",
  "version": "1.0.0",
  "description": "FirstMileDev website - Market-First MVP Agency",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:css": "tailwindcss -i ./src/app/globals.css -o ./dist/styles.css --minify",
    "build:js": "terser script.js -o dist/script.min.js --compress --mangle && terser navbar.js -o dist/navbar.min.js --compress --mangle && terser footer.js -o dist/footer.min.js --compress --mangle && terser blog.js -o dist/blog.min.js --compress --mangle && terser calculator.js -o dist/calculator.min.js --compress --mangle",
    "watch:css": "tailwindcss -i ./src/app/globals.css -o ./dist/styles.css --watch",
    "old-build": "npm run build:css && npm run build:js",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "jest": "^29.7.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.3",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}

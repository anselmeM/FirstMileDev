{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.firstmiledev.ca"
        }
      ],
      "destination": "https://firstmiledev.ca/$1",
      "permanent": true
    }
  ]
}

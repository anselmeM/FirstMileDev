# =====================================================
# COMPREHENSIVE .GITIGNORE FOR WEB PROJECTS
# =====================================================
# This file defines patterns for files that should NOT be tracked in version control.
# Each section is organized by category with explanations.
# Maintained by: Update as your project evolves
# =====================================================

# -------------------------------------------------------
# SECTION 1: OPERATING SYSTEM FILES
# -------------------------------------------------------
# These files are generated by the operating system and are different
# across team members' machines. Never track these.

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?
.documentIcon

# Linux
*~ 
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -------------------------------------------------------
# SECTION 2: EDITOR AND IDE CONFIGURATIONS
# -------------------------------------------------------
# IDE-specific files. Some teams choose to track .idea/ if they
# want consistent team-wide IDE settings. Comment out what you prefer.

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
out/

# Sublime Text
*.tmlanguage.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
*.sublime-session

# Vim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Atom
.atom/
.buildlog
.history/

# -------------------------------------------------------
# SECTION 3: TEMPORARY AND BACKUP FILES
# -------------------------------------------------------
# These files are often created during editing or as backups.
# They rarely contain useful project code.

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.backup
*.orig
*.rej

# Patch and diff files (often auto-generated)
*.diff
*.patch
*.patch2

# Build artifacts from different processes
*.swp
*.swo

# -------------------------------------------------------
# SECTION 4: BUILD OUTPUTS AND GENERATED FILES
# -------------------------------------------------------
# Files generated during the build process. These can be
# regenerated from source code and shouldn't be versioned.

# Node.js build outputs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
package-lock.json

# Tailwind CSS (if building locally)
style.css
style.css.map

# General build directories
dist/
build/
out/
target/

# Compiled code
*.class
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.dll
*.exe

# Minified/optimized files (keep source, ignore minified)
*.min.js
*.min.css
*.min.html

# -------------------------------------------------------
# SECTION 5: ENVIRONMENT AND CONFIGURATION FILES
# -------------------------------------------------------
# These often contain sensitive information or are
# environment-specific.

# Environment variables (.env files)
.env
.env.local
.env.*.local
.env.development
.env.production

# API keys and secrets (example patterns)
*.pem
*.key
*.crt
*.p12
*.pfx

# Configuration files with secrets
config.ini
secrets.json
credentials.json

# -------------------------------------------------------
# SECTION 6: TESTING AND COVERAGE FILES
# -------------------------------------------------------
# Generated during testing. Can be regenerated.

coverage/
.nyc_output/
htmlcov/
*.lcov

# Test results
test-results/
junit.xml
*.log

# -------------------------------------------------------
# SECTION 7: DOCUMENTATION AND MARKDOWN FILES (SELECTIVE)
# -------------------------------------------------------
# Not all markdown files should be ignored. Use this section
# for generated documentation, NOT your project documentation.

# Auto-generated documentation
docs/_build/
site/

# Build notes and process documentation (if generated)
TAILWIND_BUILD.md
BUILD_NOTES.md
CHANGELOG.md

# NOTE: Keep these important markdown files:
# !README.md
# !CONTRIBUTING.md
# !LICENSE.md

# -------------------------------------------------------
# SECTION 8: CACHE AND CACHE DIRECTORIES
# -------------------------------------------------------
# Various caching directories that shouldn't be tracked

# Package manager caches
.npm
.yarn/

# Build tool caches
.cache/
.parcel-cache/
.nuxt/
.vercel/
.next/

# Browser caches
ServiceWorkerCache/

# -------------------------------------------------------
# SECTION 9: MEDIA AND BINARY FILES (OPTIONAL)
# -------------------------------------------------------
# Large binary files can bloat the repository. Uncomment
# if your team uses Git LFS or if you want to manage these separately.

# Build images (can be regenerated)
# images/*.png
# images/*.jpg
# images/*.svg

# Favicons and icons (if generated)
# favicon.ico is typically kept (it appears in root)
# icon-*.png

# -------------------------------------------------------
# SECTION 10: PROJECT-SPECIFIC FILES
# -------------------------------------------------------
# Add project-specific ignores below this line

# Manifest and service worker (usually generated or cached)
sw.js
manifest.json

# CNAME (managed by hosting platform, e.g., GitHub Pages)
CNAME

# Robot directives
robots.txt

# -------------------------------------------------------
# SECTION 11: EXCEPTIONS (FILES TO ALWAYS TRACK)
# -------------------------------------------------------
# These files should ALWAYS be tracked in version control

# Configuration files that should be in the repo
!package.json
!package-lock.json
!tailwind.config.js

# Documentation (if wanted)
!README.md
!CONTRIBUTING.md

# Source files
!index.html
!src/**
!</path>/** (adjust for your project structure)

# -------------------------------------------------------
# ADDITIONAL BEST PRACTICES:
# -------------------------------------------------------
# 1. Run 'git check-ignore -v <filename>' to test patterns
# 2. Use 'git status --ignored' to see what's being ignored
# 3. Review your .gitignore quarterly to remove outdated patterns
# 4. Document project-specific patterns in your README
# 5. Consider using gitignore.io for language-specific templates
# 6. For large binaries, consider Git LFS (git lfs install)
# 7. Use global .gitignore for personal system files:
#    git config --global core.excludesFile ~/.gitignore
# 8. Test new patterns in a staging area before committing